<?xml version="1.0"?>
<robot name="my_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ===================== -->
  <!-- Basic parameters      -->
  <!-- ===================== -->
  <xacro:property name="body_length" value="0.8"/>
  <xacro:property name="body_width"  value="0.59"/>
  <xacro:property name="body_height" value="0.19"/>

  <xacro:property name="wheel_separation" value="0.38"/>
  <xacro:property name="wheel_radius" value="0.0625"/>
  <xacro:property name="wheel_thickness" value="0.04"/>

  <xacro:property name="caster_radius" value="0.051"/>
  <xacro:property name="caster_thickness" value="0.03"/>

  <!-- mesh file -->
  <xacro:property name="body_mesh_file" value="package://description/meshes/mesh.stl"/>
  <xacro:property name="body_mesh_scale" value="1 1 1"/>

  <!-- mesh origin correction -->
  <xacro:property name="body_mesh_x" value="0.0"/>
  <xacro:property name="body_mesh_y" value="0.0"/>
  <xacro:property name="body_mesh_z" value="0.0"/>

  <xacro:property name="body_mesh_roll" value="0.0"/>
  <xacro:property name="body_mesh_pitch" value="0.0"/>
  <xacro:property name="body_mesh_yaw" value="0.0"/>

  <!-- ROS-converted sensor positions -->
  <xacro:property name="lidar_x" value="0.27"/>
  <xacro:property name="lidar_y" value="0.0"/>
  <xacro:property name="lidar_z" value="0.175"/>

  <xacro:property name="imu_x" value="0.30"/>
  <xacro:property name="imu_y" value="0.0"/>
  <xacro:property name="imu_z" value="0.0"/>

  <xacro:property name="tof0_x" value="0.22"/>
  <xacro:property name="tof0_y" value="0.32"/>
  <xacro:property name="tof0_z" value="0.15"/>

  <xacro:property name="tof1_x" value="0.22"/>
  <xacro:property name="tof1_y" value="-0.32"/>
  <xacro:property name="tof1_z" value="0.15"/>

  <xacro:property name="tof2_x" value="-0.55"/>
  <xacro:property name="tof2_y" value="0.28"/>
  <xacro:property name="tof2_z" value="0.15"/>

  <xacro:property name="tof3_x" value="-0.55"/>
  <xacro:property name="tof3_y" value="-0.28"/>
  <xacro:property name="tof3_z" value="0.15"/>

  <!-- ===================== -->
  <!-- Materials             -->
  <!-- ===================== -->
  <material name="gray">
    <color rgba="0.6 0.6 0.6 1.0"/>
  </material>

  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>

  <material name="blue">
    <color rgba="0.2 0.4 1.0 1.0"/>
  </material>

  <material name="green">
    <color rgba="0.2 0.8 0.2 1.0"/>
  </material>

  <!-- ===================== -->
  <!-- base_footprint        -->
  <!-- ===================== -->
  <link name="base_footprint"/>

  <joint name="base_footprint_to_base_link" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- ===================== -->
  <!-- base_link             -->
  <!-- ===================== -->
  <link name="base_link">
    <visual>
      <origin xyz="${body_mesh_x} ${body_mesh_y} ${body_mesh_z}"
              rpy="${body_mesh_roll} ${body_mesh_pitch} ${body_mesh_yaw}"/>
      <geometry>
        <mesh filename="${body_mesh_file}" scale="${body_mesh_scale}"/>
      </geometry>
      <material name="gray"/>
    </visual>

    <collision>
      <origin xyz="0 0 ${body_height/2.0 - wheel_radius}" rpy="0 0 0"/>
      <geometry>
        <box size="${body_length} ${body_width} ${body_height}"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="15.0"/>
      <inertia ixx="0.5" ixy="0.0" ixz="0.0"
               iyy="0.8" iyz="0.0"
               izz="1.0"/>
    </inertial>
  </link>

  <!-- ===================== -->
  <!-- Left wheel            -->
  <!-- ===================== -->
  <link name="left_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 ${pi/2} 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 ${pi/2} 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0"
               iyy="0.01" iyz="0.0"
               izz="0.01"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <origin xyz="0 ${wheel_separation/2.0} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ===================== -->
  <!-- Right wheel           -->
  <!-- ===================== -->
  <link name="right_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 ${pi/2} 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 ${pi/2} 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0"
               iyy="0.01" iyz="0.0"
               izz="0.01"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel_link"/>
    <origin xyz="0 ${-wheel_separation/2.0} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ===================== -->
  <!-- Caster wheel          -->
  <!-- ===================== -->
  <link name="caster_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 ${pi/2} 0"/>
      <geometry>
        <cylinder radius="${caster_radius}" length="${caster_thickness}"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 ${pi/2} 0"/>
      <geometry>
        <cylinder radius="${caster_radius}" length="${caster_thickness}"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.003" ixy="0.0" ixz="0.0"
               iyy="0.003" iyz="0.0"
               izz="0.003"/>
    </inertial>
  </link>

  <joint name="caster_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel_link"/>
    <origin xyz="-0.30 0 ${-(wheel_radius - caster_radius)}" rpy="0 0 0"/>
  </joint>

  <!-- ===================== -->
  <!-- LiDAR                 -->
  <!-- ===================== -->
  <link name="lidar_link">
    <visual>
      <geometry>
        <box size="0.037 0.037 0.024"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.037 0.037 0.024"/>
      </geometry>
    </collision>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="${lidar_x} ${lidar_y} ${lidar_z}" rpy="0 0 0"/>
  </joint>

  <!-- ===================== -->
  <!-- IMU                   -->
  <!-- ===================== -->
  <link name="imu_link">
    <visual>
      <geometry>
        <box size="0.04 0.04 0.02"/>
      </geometry>
      <material name="green"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.04 0.04 0.02"/>
      </geometry>
    </collision>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="${imu_x} ${imu_y} ${imu_z}" rpy="0 0 0"/>
  </joint>

  <!-- ===================== -->
  <!-- ToF sensors           -->
  <!-- ===================== -->
  <xacro:macro name="tof_sensor" params="name px py pz yaw">
    <link name="${name}">
      <visual>
        <geometry>
          <box size="0.03 0.02 0.02"/>
        </geometry>
        <material name="blue"/>
      </visual>
      <collision>
        <geometry>
          <box size="0.03 0.02 0.02"/>
        </geometry>
      </collision>
    </link>

    <joint name="${name}_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${name}"/>
      <origin xyz="${px} ${py} ${pz}" rpy="0 0 ${yaw}"/>
    </joint>
  </xacro:macro>

  <xacro:tof_sensor name="tof_link_0" px="${tof0_x}" py="${tof0_y}" pz="${tof0_z}" yaw="0"/>
  <xacro:tof_sensor name="tof_link_1" px="${tof1_x}" py="${tof1_y}" pz="${tof1_z}" yaw="0"/>
  <xacro:tof_sensor name="tof_link_2" px="${tof2_x}" py="${tof2_y}" pz="${tof2_z}" yaw="${pi}"/>
  <xacro:tof_sensor name="tof_link_3" px="${tof3_x}" py="${tof3_y}" pz="${tof3_z}" yaw="${pi}"/>

</robot>